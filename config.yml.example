# Warpbox Configuration
# Copy this file to config.yml and fill in your values.
#
# Every setting in this file has a documented purpose, default value,
# valid options/range, and whether it is required or optional.

# ---------------------------------------------------------------------------
# TorBox API Connection
# ---------------------------------------------------------------------------
torbox:
  # Your TorBox API key (required).
  # Obtain it from your TorBox account dashboard.
  api_key: ""

# ---------------------------------------------------------------------------
# WebDAV Server Settings
# ---------------------------------------------------------------------------
server:
  # Network address and port the WebDAV server listens on.
  # Optional. Default: ":1412"
  # Type: string (host:port). Valid: any valid Go net.Listen address.
  # Examples: ":1412" (all interfaces), "127.0.0.1:1412" (loopback only).
  listen_addr: ":1412"

  # Root URL path for the WebDAV service.
  # Optional. Default: "/webdav"
  # Type: string (path). Valid: any URL path segment.
  # rclone would use: http://localhost:1412/webdav/ as the URL.
  webdav_root: "/webdav"

# ---------------------------------------------------------------------------
# JIT RAM Cache Configuration
# ---------------------------------------------------------------------------
cache:
  # Size of each pre-fetched chunk in megabytes.
  # When a file read starts, Warpbox fetches this much data ahead and
  # holds it in RAM for sequential reads.
  # Optional. Default: 16. Valid range: 1–1024.
  chunk_size_mb: 16

  # Maximum RAM to use for cached chunks in megabytes.
  # When this limit is reached, chunks are evicted according to
  # eviction_strategy to make room.
  # Optional. Default: 512. Valid range: 64–16384.
  max_ram_mb: 512

  # Time-to-live for cached chunks in seconds.
  # Chunks not accessed within this window are evicted from RAM.
  # Only applies when eviction_strategy is "ttl".
  # Optional. Default: 30. Valid range: 5–86400 (1 second to 24 hours).
  ttl_seconds: 30

  # Cache eviction strategy.
  # - "ttl" — Evict chunks after ttl_seconds of inactivity. Simple and
  #   predictable. Best for most use cases.
  # - "lru" — Evict the least recently used chunks when max_ram_mb is
  #   exceeded. More memory-efficient under pressure but slightly more
  #   CPU overhead.
  # Optional. Default: "ttl".
  eviction_strategy: "ttl"

  # How long to cache TorBox CDN download URLs in minutes.
  # CDN URLs are valid for several hours. Caching them avoids a TorBox
  # API call on every range request. Set to 0 to disable CDN URL caching
  # (not recommended — increases API load).
  # Optional. Default: 120. Valid range: 0–1440.
  cdn_url_ttl_minutes: 120

  # Enable automatic repair of stale CDN download URLs.
  # When the CDN returns 403/404, Warpbox silently fetches a fresh URL
  # from TorBox (via the throttle queue) and retries the request. This
  # prevents broken files in Plex/Jellyfin when URLs expire within the
  # cache window.
  # Optional. Default: true.
  cdn_url_auto_repair: true

  # Maximum number of CDN URL repair attempts per request before giving up.
  # Each attempt makes a rate-limited TorBox API call, so keep this low.
  # Set to 0 to disable retries regardless of cdn_url_auto_repair.
  # Optional. Default: 2. Valid range: 0–10.
  cdn_url_repair_retries: 2

  # Base backoff interval in seconds for CDN URL fetch retries.
  # When TorBox returns a 5xx or 429 error, the fetch is retried with
  # exponential backoff: backoff * 1s, * 2s, * 4s, etc.
  # Optional. Default: 1. Valid range: 1–60.
  cdn_url_retry_backoff: 1

  # Maximum number of CDN URL fetch retry attempts on TorBox API errors.
  # Each retry makes a rate-limited API call, so keep this low.
  # Set to 0 to disable retries (not recommended — transient errors
  # will immediately fail).
  # For server-side errors like DATABASE_ERROR ("try again later"),
  # retrying multiple times just burns the rate budget. 1 retry
  # is usually enough.
  # Optional. Default: 1. Valid range: 0–10.
  cdn_url_retry_attempts: 1

  # How long to cache failed CDN URL lookups in seconds (negative cache).
  # When fetchCDNURL fails for a specific (torrent_id, file_id), subsequent
  # requests for the same file within this window return the cached error
  # without making an API call. This prevents Plex's retry loop from
  # hammering TorBox with the same failing request.
  # Optional. Default: 30. Valid range: 1–300.
  negative_cache_ttl_seconds: 30

  # Circuit breaker: maximum number of failed CDN URL fetches per torrent
  # within the sliding window. Once exceeded, the torrent is marked "stale"
  # and all CDN URL fetches for all files in that torrent are skipped until
  # the stale period expires. Reset automatically when stale period ends.
  # Optional. Default: 5. Valid range: 1–100.
  circuit_breaker_failures: 5

  # Circuit breaker: sliding window duration in seconds for counting failures.
  # Optional. Default: 60. Valid range: 1–3600.
  circuit_breaker_window_seconds: 60

  # Circuit breaker: how many minutes a stale torrent is skipped for.
  # When a torrent is marked stale, all CDN URL fetches for its files are
  # skipped until this period expires. At that point the torrent is retried.
  # Optional. Default: 5. Valid range: 1–60.
  circuit_breaker_stale_minutes: 5

# ---------------------------------------------------------------------------
# Rate-Limiting / Throttle
# ---------------------------------------------------------------------------
throttle:
  # Maximum number of API requests allowed per minute to TorBox.
  # TorBox enforces a 300 requests/minute hard limit. Set this lower to
  # maintain a safety margin.
  # Optional. Default: 250. Valid range: 10–290.
  requests_per_minute: 250

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
logging:
  # Log output format.
  # - "text" — Human-readable key=value pairs. Best for local development
  #   and debugging. Shows timestamps, log level, and message inline.
  # - "json" — Structured JSON objects. Best for production environments
  #   and log aggregation systems (e.g., Loki, Datadog, ELK).
  # Optional. Default: "text".
  format: "text"

  # Log verbosity level.
  # - "debug" — Verbose logging including every PROPFIND/GET/HEAD request.
  # - "info" — Normal operational messages.
  # - "warn" — Warning conditions.
  # - "error" — Error conditions only.
  # Optional. Default: "info".
  level: "debug"

# ---------------------------------------------------------------------------
# Metadata Sync
# ---------------------------------------------------------------------------
sync:
  # How often to refresh the local SQLite metadata cache from TorBox.
  # A full sync calls the TorBox API once, so the throttle rate applies.
  # Optional. Default: 5. Valid range: 1–1440 (1 minute to 24 hours).
  interval_minutes: 5