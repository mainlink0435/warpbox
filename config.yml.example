# Warpbox Configuration
# ======================
# This file documents every possible configuration key with its default value
# and purpose. Uncomment and adjust values as needed.

torbox:
  # TorBox API key (required). Generate one from your TorBox account dashboard.
  api_key: "changeme"

server:
  # Network address the WebDAV server listens on.
  # Default: ":1412"
  listen_addr: ":1412"

  # WebDAV root is always /webdav. Virtual paths (if configured) appear as
  # subdirectories under /webdav/ — e.g., /webdav/__all__/, /webdav/movies/.

  # Enable /debug/pprof/ endpoints for runtime profiling.
  # When enabled, heap profiles, goroutine stacks, and CPU profiles are
  # exposed. Disable in production unless actively debugging.
  # Default: false
  # enable_pprof: false

cache:
  # How long to cache CDN download URLs (in minutes).
  # TorBox CDN URLs expire after a few hours. Setting this too high
  # will serve stale URLs and cause 404 errors.
  # Must be 1–1440 (1 minute to 24 hours). Default: 120
  # cdn_url_ttl_minutes: 120

  # Automatically repair stale CDN URLs when a 404 is detected during proxy.
  # When enabled, a CDN URL that returns 404 will be refreshed transparently.
  # Default: true
  # cdn_url_auto_repair: true

  # Maximum number of retries for CDN proxy requests that fail with a 404
  # (after CDN URL repair). 0 means no retries.
  # Default: 2
  # cdn_url_repair_retries: 2

  # CDN URL fetch retry settings (for TorBox API errors, not CDN proxy errors).
  # Backoff base in seconds between retry attempts.
  # Default: 1
  # cdn_url_retry_backoff: 1
  # Maximum number of retry attempts when fetching a CDN URL from TorBox.
  # Default: 1
  # cdn_url_retry_attempts: 1

  # Negative cache TTL (in seconds).
  # When a CDN URL fetch fails, the failure is cached briefly to prevent
  # Plex/jellyfin retry storms from hammering the TorBox API.
  # Must be 1–300. Default: 30
  # negative_cache_ttl_seconds: 30

  # Circuit breaker: per-torrent failure tracking.
  # Number of failures within the window before the breaker trips.
  # Default: 5
  # circuit_breaker_failures: 5
  # Sliding window in seconds for counting failures.
  # Default: 60
  # circuit_breaker_window_seconds: 60
  # Minutes the breaker stays tripped before auto-reset.
  # Default: 5
  # circuit_breaker_stale_minutes: 5

  # Memory management settings.
  # Default: 5000
  # negative_cache_max_entries: 5000
  # Default: 2000
  # circuit_breaker_max_entries: 2000
  # How often to sweep expired cache entries (in seconds). Must be 10–3600.
  # Default: 60
  # cleanup_interval_seconds: 60

  # Maximum concurrent CDN proxy connections.
  # Default: 4
  # max_cdn_connections: 4

throttle:
  # Maximum sustained TorBox API requests per minute.
  # The free TorBox plan allows 300 RPM. Setting this higher will result
  # in 429 errors. Must be 10–1000.
  # Default: 250
  requests_per_minute: 250

logging:
  # Output format: "text" for human-readable, "json" for structured logging.
  # Default: "text"
  # format: "text"

  # Log level: "debug", "info", "warn", or "error".
  # Default: "info"
  # level: "info"

sync:
  # How often to sync metadata from TorBox (in minutes).
  # Must be 1–1440. Default: 5
  # interval_minutes: 5

  # Maximum number of files to fetch per sync cycle.
  # Must be 1–100000. Default: 5000
  # limit: 5000

  # Items per page when paginating the mylist API.
  # TorBox caps each response at ~10,000 items, so Warpbox pages through
  # with this window size. Lower = more API calls but safer; higher = fewer
  # calls but risks hitting the cap. Must be 1–10000. Default: 5000
  # list_page_size: 5000

  # Maximum number of retry attempts for transient API errors (502, timeout,
  # HTML error pages) during sync. 0 means no retry.
  # Default: 3
  # retry_attempts: 3

  # Base backoff in seconds between sync retry attempts.
  # Exponential: backoff * 1s, * 2s, * 4s for attempts 1, 2, 3.
  # Must be 1–60. Default: 1
  # retry_backoff: 1

library:
  # Virtual library paths: filtered views over the raw TorBox file tree.
  # Each virtual path has its own regex filters that determine which
  # directories (torrents) and files are visible. Multiple virtual paths
  # can share files — the same torrent appearing in /movies and /tv.
  # The raw /webdav mount (__all__) always shows everything unfiltered.
  virtual_paths:
    - name: movies
      directory_exclude: "(?i)(season|episode)s?\\.?\\d?|[se]\\d\\d|\\b(tv|complete)|\\b(saison|stage)\\.?\\d|[a-z]\\s?-\\s?\\d{2,4}\\b|\\d{2,4}\\s?-\\s?\\d{2,4}\\b"
      file_regex: ".*\\.(mkv|mp4|avi)$"
      largest_file_only: true
    - name: tv
      directory_include: "(?i)(season|episode)s?\\.?\\d?|[se]\\d\\d|\\b(tv|complete)|\\b(saison|stage)\\.?\\d|[a-z]\\s?-\\s?\\d{2,4}\\b|\\d{2,4}\\s?-\\s?\\d{2,4}\\b"
      file_regex: ".*\\.(mkv|mp4|avi)$"
      largest_file_only: true

  # Shell command to run when items are added to the library (after sync).
  # Receives item directory names as positional arguments.
  # Example: "curl -X POST http://plex:32400/library/sections/1/refresh"
  # on_items_added: ""
  #
  # Shell command to run when items are removed from the library (after sync).
  # Receives item directory names as positional arguments.
  # on_items_removed: ""
  #
  # Timeout in seconds for the hook commands. If a hook exceeds this, it is
  # killed and a warning is logged. Must be 1–3600. Default: 30.
  # hook_timeout_seconds: 30

auth:
  # Enable HTTP Basic Authentication for the web management UI.
  # When enabled, the landing page, logs, actions, stats, and HTTP browser
  # all require a username and password. The WebDAV, Infuse, and /healthz
  # endpoints are NOT protected — they are consumed by rclone, Plex,
  # Infuse, and Docker healthchecks respectively.
  # Default: false
  # enabled: false

  # Username for HTTP Basic Auth. Default: "admin"
  # username: "admin"

  # Password for HTTP Basic Auth (required when enabled).
  # password: "changeme"

stats:
  # How often to record time-series stats snapshots (in seconds).
  # Snapshots include API call counts, memory usage, cache stats, etc.
  # These are displayed as sparkline charts on the landing page.
  # Must be 10–3600. Default: 60
  # interval_seconds: 60

  # How long to retain stats rows (in hours).
  # Older rows are automatically pruned during each stats interval.
  # Must be 1–720 (1 hour to 30 days). Default: 24
  # retention_hours: 24

  # How far back the landing page sparkline chart shows (in minutes).
  # Must be 1–1440. Default: 60
  # chart_minutes: 60
